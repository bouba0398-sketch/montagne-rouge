# ─────────────────────────────────────────────────────────────
#  Montagne Rouge — Variables d'environnement
#  Copier ce fichier en .env.local pour le développement local
#  NE JAMAIS committer .env.local dans git
# ─────────────────────────────────────────────────────────────

# ── Supabase (PUBLIC — inclus dans le bundle client si NEXT_PUBLIC_)
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# ── Supabase (SERVER ONLY — ne jamais exposer côté client)
# Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ── Resend (SERVER ONLY — envoi d'emails)
# https://resend.com → API Keys
RESEND_API_KEY=

# ── Email destinataire des formulaires
# Par défaut : montagnerouge1996@gmail.com si non défini
EMAIL_TO=

# ── UploadThing (si encore utilisé ailleurs)
# https://uploadthing.com → Dashboard → API Keys
UPLOADTHING_TOKEN=
