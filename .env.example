# ─────────────────────────────────────────────
#  Montagne Rouge — Variables d'environnement
#  Copier ce fichier en .env.local pour le dev
#  NE JAMAIS committer .env.local dans git
# ─────────────────────────────────────────────

# Resend — envoi des emails (contact + inscriptions)
# https://resend.com → API Keys
RESEND_API_KEY=

# Adresse email qui reçoit les messages du site
# Par défaut : bouba0398@gmail.com si non défini
EMAIL_TO=

# UploadThing — upload de documents (dossier d'inscription)
# https://uploadthing.com → Dashboard → API Keys
UPLOADTHING_TOKEN=
