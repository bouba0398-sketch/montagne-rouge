# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Vidéos de développement à la racine (trop lourdes pour git)
/hero2.mp4

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — secrets locaux (jamais committer)
.env.local
.env*.local
# .env.example est commité intentionnellement (pas de secrets, juste les noms de vars)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
